# Docker Hub
DOCKER_USERNAME=your_docker_username

# Server
SERVER_HTTP_ADDR=0.0.0.0:8080

# Database
DATABASE_DRIVER=postgres
DATABASE_CONNECTION=host=postgres port=5432 user=myuser password=your_postgres_password dbname=mydb sslmode=disable
POSTGRES_USER=myuser
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=mydb

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# Visual AI
VISUAL_AI_API_KEY=your_api_key
VISUAL_AI_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions
VISUAL_AI_MODEL=GLM-4.1V-Thinking-Flash
VISUAL_AI_PROVIDER=glm

# Email SMTP
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USERNAME=your_email@163.com
SMTP_PASSWORD=your_smtp_password

# JWT
JWT_SECRET=your_jwt_secret
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_HOURS=168

# WeChat
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# Publish Email
PUBLISH_EMAIL_ENABLED=true
