{
    "swagger": "2.0",
    "info": {
        "description": "This is a DDL Guard server API.",
        "title": "DDL Guard API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/api/v1",
    "paths": {
        "/auth/refresh-tokens": {
            "post": {
                "description": "使用refresh token换取新的access token和refresh token",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "刷新Token",
                "parameters": [
                    {
                        "description": "Refresh Token Request",
                        "name": "req",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/schema.RefreshTokenReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "success",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/handler.resp"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/schema.TokenPairResp"
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/ddl/draft": {
            "post": {
                "description": "创建DDL草稿",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "DDL"
                ],
                "summary": "创建DDL草稿",
                "parameters": [
                    {
                        "description": "Create Draft Request",
                        "name": "req",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/schema.CreateDraftReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "success",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/handler.resp"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/schema.CreateDraftResp"
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/ddl/drafts/{uuid}": {
            "patch": {
                "description": "将草稿状态从draft变更为active",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "DDL"
                ],
                "summary": "同意DDL草稿",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Draft UUID",
                        "name": "uuid",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Update Draft Status Request",
                        "name": "req",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/schema.UpdateDraftStatusReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "success",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/handler.resp"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/schema.UpdateDraftStatusResp"
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/users/email/verification-codes": {
            "post": {
                "description": "发送邮箱验证码用于注册",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "User"
                ],
                "summary": "发送邮箱验证码",
                "parameters": [
                    {
                        "description": "Send Email Verification Code Request",
                        "name": "req",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/schema.SendEmailVerificationCodeReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "success",
                        "schema": {
                            "$ref": "#/definitions/handler.resp"
                        }
                    }
                }
            }
        },
        "/users/password": {
            "put": {
                "description": "使用验证码验证身份后修改用户密码。验证码通过 SendPasswordResetCode 接口发送。\ntype: 验证方式，需与发送验证码时的类型一致，目前支持 \"email\"\ntarget: 验证目标，需与发送验证码时的目标一致\ncode: 收到的验证码，6 位数字\nnew_password: 新密码，最少 6 个字符",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "User"
                ],
                "summary": "通过验证码修改密码",
                "parameters": [
                    {
                        "description": "修改密码请求",
                        "name": "req",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/schema.ChangePasswordReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "密码修改成功",
                        "schema": {
                            "$ref": "#/definitions/handler.resp"
                        }
                    },
                    "400": {
                        "description": "请求参数错误或验证码无效",
                        "schema": {
                            "$ref": "#/definitions/handler.resp"
                        }
                    },
                    "404": {
                        "description": "用户不存在",
                        "schema": {
                            "$ref": "#/definitions/handler.resp"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/handler.resp"
                        }
                    }
                }
            }
        },
        "/users/password/reset-codes": {
            "post": {
                "description": "根据指定的验证类型发送验证码到目标地址。目前支持 email 类型，验证码有效期为 5 分钟。\ntype: 验证方式，目前支持 \"email\"\ntarget: 验证目标，邮箱类型时为邮箱地址",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "User"
                ],
                "summary": "发送密码重置验证码",
                "parameters": [
                    {
                        "description": "发送密码重置验证码请求",
                        "name": "req",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/schema.SendPasswordResetCodeReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "验证码发送成功",
                        "schema": {
                            "$ref": "#/definitions/handler.resp"
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/handler.resp"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/handler.resp"
                        }
                    }
                }
            }
        },
        "/users/registrations/email": {
            "post": {
                "description": "使用邮箱验证码注册用户",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "User"
                ],
                "summary": "邮箱注册",
                "parameters": [
                    {
                        "description": "Register User By Email Request",
                        "name": "req",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/schema.RegisterUserByEmailReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "success",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/handler.resp"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/schema.RegisterUserByEmailResp"
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/users/sessions/email": {
            "post": {
                "description": "使用邮箱和密码登录",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "User"
                ],
                "summary": "邮箱登录",
                "parameters": [
                    {
                        "description": "Login By Email Request",
                        "name": "req",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/schema.LoginByEmailReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "success",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/handler.resp"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/schema.LoginByEmailResp"
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handler.resp": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "data": {},
                "message": {
                    "type": "string"
                }
            }
        },
        "schema.ChangePasswordReq": {
            "type": "object",
            "required": [
                "code",
                "new_password",
                "target",
                "type"
            ],
            "properties": {
                "code": {
                    "type": "string",
                    "example": "123456"
                },
                "new_password": {
                    "type": "string",
                    "minLength": 6,
                    "example": "newpassword123"
                },
                "target": {
                    "type": "string",
                    "example": "user@example.com"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "email"
                    ],
                    "example": "email"
                }
            }
        },
        "schema.CreateDraftInput": {
            "type": "object",
            "properties": {
                "deadline": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-03-24T14:30:00+08:00"
                },
                "description": {
                    "type": "string",
                    "example": "from swagger"
                },
                "early_remind": {
                    "type": "integer",
                    "example": 30
                },
                "title": {
                    "type": "string",
                    "example": "test ddl"
                }
            }
        },
        "schema.CreateDraftReq": {
            "type": "object",
            "properties": {
                "data_type": {
                    "type": "string",
                    "default": "default",
                    "example": "default"
                },
                "draft": {
                    "$ref": "#/definitions/schema.CreateDraftInput"
                },
                "raw_base64": {
                    "type": "string",
                    "example": "iVBORw0KGgoAAAANSUhEUgAA..."
                }
            }
        },
        "schema.CreateDraftResp": {
            "type": "object",
            "properties": {
                "deadline": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-03-24T14:30:00+08:00"
                },
                "description": {
                    "type": "string",
                    "example": "from swagger"
                },
                "early_remind": {
                    "type": "integer",
                    "example": 30
                },
                "title": {
                    "type": "string",
                    "example": "test ddl"
                },
                "uuid": {
                    "type": "string",
                    "example": "7a178766-4b8e-4e99-ab4c-843f7dbd95fd"
                }
            }
        },
        "schema.LoginByEmailReq": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "example": "testuser@example.com"
                },
                "password": {
                    "type": "string",
                    "example": "password123"
                }
            }
        },
        "schema.LoginByEmailResp": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                },
                "refresh_token": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                },
                "username": {
                    "type": "string",
                    "example": "testuser"
                },
                "uuid": {
                    "type": "string",
                    "example": "7a178766-4b8e-4e99-ab4c-843f7dbd95fd"
                }
            }
        },
        "schema.RefreshTokenReq": {
            "type": "object",
            "required": [
                "refresh_token"
            ],
            "properties": {
                "refresh_token": {
                    "type": "string"
                }
            }
        },
        "schema.RegisterUserByEmailReq": {
            "type": "object",
            "required": [
                "code",
                "email",
                "password",
                "username"
            ],
            "properties": {
                "code": {
                    "type": "string",
                    "example": "123456"
                },
                "email": {
                    "type": "string",
                    "example": "testuser@example.com"
                },
                "password": {
                    "type": "string",
                    "minLength": 6,
                    "example": "password123"
                },
                "username": {
                    "type": "string",
                    "example": "testuser"
                }
            }
        },
        "schema.RegisterUserByEmailResp": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                },
                "refresh_token": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                },
                "uuid": {
                    "type": "string",
                    "example": "7a178766-4b8e-4e99-ab4c-843f7dbd95fd"
                }
            }
        },
        "schema.SendEmailVerificationCodeReq": {
            "type": "object",
            "required": [
                "email"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "example": "testuser@example.com"
                }
            }
        },
        "schema.SendPasswordResetCodeReq": {
            "type": "object",
            "required": [
                "target",
                "type"
            ],
            "properties": {
                "target": {
                    "type": "string",
                    "example": "user@example.com"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "email"
                    ],
                    "example": "email"
                }
            }
        },
        "schema.TokenPairResp": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                },
                "refresh_token": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                }
            }
        },
        "schema.UpdateDraftStatusReq": {
            "type": "object",
            "required": [
                "status"
            ],
            "properties": {
                "status": {
                    "type": "string",
                    "example": "active"
                }
            }
        },
        "schema.UpdateDraftStatusResp": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "integer",
                    "example": 1
                },
                "uuid": {
                    "type": "string",
                    "example": "7a178766-4b8e-4e99-ab4c-843f7dbd95fd"
                }
            }
        }
    }
}