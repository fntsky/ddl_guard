server:
  http:
    addr: 0.0.0.0:8080
data:
  database:
    driver: "postgres"
    connection: "host=localhost port=5432 user=myuser password=postgre dbname=mydb sslmode=disable"
VISUAL_AI:
  api_key: "your_api_key_here"
  endpoint: "https://api.visualai.com/v1/analyze"
  model: "default"
  provider: "visual_ai"
    
EMAIL_OTP:
  smtp:
    host: "example.smtp.com"
    port: 465
    username: "example@smtp.com"
    password: "your_smtp_password"

jwt:
  secret: "change_me_to_a_strong_secret"
  access_ttl_minutes: 15
  refresh_ttl_hours: 168
